<TEI xmlns:ns0="http://tei-c.org"><text><body><div><p><note n="a" />Ego <persName xml:id="p1" key="Ramon Berenguer III el Gran" role="donador">Raimundus Berengarii, Barchinonensis comes</persName>, dono ad fevum tibi <persName xml:id="p2" key="Bernat Ató IV de Besiers" role="beneficiari">Bernardo Atonis, Biterrensi vicecomiti</persName>, <placeName xml:id="pl1" key="Boisseson, castell">Boxazon</placeName>,<note n="b" /> <placeName xml:id="pl2" key="Ròcacerièra, castell" type="castell">Roccam Cedam</placeName>,<note n="c" /> <placeName xml:id="pl3" key="Ambialet, castell">Ambiletum</placeName>, <placeName xml:id="pl4" key="Curvala, castell">Curvallem</placeName>, <placeName xml:id="pl5" key="Cailar, Lo, castell"><hi rend="italic">Castlar</hi></placeName>, <placeName xml:id="pl6" key="Pesenàs, castell i vila"><hi rend="italic">Pedenaz</hi></placeName>, <placeName xml:id="pl7" key="Castèlnòu" type="castell">Castellum Novum</placeName>, <placeName xml:id="pl8" key="Mesa, castell">Messoam</placeName>, <placeName xml:id="pl9" key="Sant Ponç de Mauchins, castell" type="castell">Castellum Sancti Poncii</placeName>, <placeName xml:id="pl10" key="Poget, Lo, castell">Poietum</placeName>, <placeName xml:id="pl11" key="Mercoirol, castell"><hi rend="italic">Mercoirol</hi></placeName> et <placeName xml:id="pl12" key="Cauviçon, castell">Calvitionem</placeName>,<note n="d" /> quod reddas illos mihi quando ego illos<note n="e" /> tibi requiram per me aut per meum missum et quod<note n="f" /> servias illos mihi.</p></div></body></text></TEI>